@inject IJSRuntime JS

<nav class="navbar">
    <div class="navbar-inner">
        <a class="navbar-brand" href="#hero">
            <span>D</span>O
        </a>
        <button class="nav-toggle" @onclick="ToggleMenu" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="nav-links @(_menuOpen ? "open" : "")">
            <a href="#summary"    @onclick="CloseMenu">About</a>
            <a href="#skills"     @onclick="CloseMenu">Skills</a>
            <a href="#experience" @onclick="CloseMenu">Experience</a>
            <a href="#hackathons" @onclick="CloseMenu">Hackathons</a>
            <a href="#education"  @onclick="CloseMenu">Education & Languages</a>
        </div>
        <button class="theme-toggle" @onclick="ToggleTheme" aria-label="Toggle theme">
            @if (_isDark)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            }
        </button>
    </div>
</nav>

@code {
    private bool _menuOpen;
    private bool _isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeToggle.getTheme");
            _isDark = theme != "light";
            StateHasChanged();
        }
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu()  => _menuOpen = false;

    private async Task ToggleTheme()
    {
        var next = await JS.InvokeAsync<string>("themeToggle.toggle");
        _isDark = next != "light";
    }
}
