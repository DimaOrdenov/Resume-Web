<section id="experience" class="section alt-bg">
    <div class="container">
        <div class="section-title">Experience</div>
        <div class="timeline reveal">
            @foreach (var exp in Experiences)
            {
                <div class="timeline-item">
                    <div class="timeline-header">
                        <span class="timeline-title">@exp.Title</span>
                        <span style="color:var(--text-secondary)">–</span>
                        <span class="timeline-company">@exp.Company</span>
                    </div>
                    <div class="timeline-meta">
                        <span class="timeline-period">
                            <CalendarSvg Width="12" Height="12"/>
                            @exp.Period
                        </span>
                        <span class="timeline-location">
                            <LocationPinSvg Width="12" Height="12"/>
                            @exp.Location
                        </span>
                    </div>
                    <ul class="timeline-bullets">
                        @foreach (var bullet in exp.Bullets)
                        {
                            <li>@bullet</li>
                        }
                    </ul>
                    @if (exp.AppLinks is { Length: > 0 })
                    {
                        <div class="app-links">
                            @{
                                var appGroups = exp.AppLinks.GroupBy(l => l.Label);
                            }
                            @foreach (var group in appGroups)
                            {
                                <div class="app-link-group">
                                    <span class="app-link-name">@group.Key</span>
                                    @foreach (var link in group)
                                    {
                                        <a class="app-link-badge app-link-badge--@link.Platform"
                                           href="@link.Url" target="_blank" rel="noopener">
                                            @if (link.Platform == "ios")
                                            {
                                                <!-- Apple logo -->
                                                <svg width="13" height="13" viewBox="0 -15 123.27 120">
                                                    <path fill-opacity="0" d="M0-15h123.27v120H0z"/>
                                                    <path fill="#FFFFFF"
                                                          d="M63.709 57.459H48.093l27.338-47.376C77.216 7 76.593 2.805 73.27.947c-3.394-1.973-7.277-.427-8.949 2.658l-2.71 4.443-2.656-4.443C57.282.52 53.399-1.088 50.004.947 46.682 2.867 46.12 7 47.907 10.083l6.416 10.86L33.174 57.46H16.759c-3.519-.001-6.789 2.594-6.789 6.477-.001 3.82 3.269 6.406 6.789 6.406h56.387c1.412-5.731-1.609-12.884-9.436-12.884zm42.806 0H90.163L72.285 26.602c-5.368 3.893-6.116 15.075-2.16 21.907l22.572 39.048c1.775 3.084 5.492 4.63 8.95 2.71 3.331-1.91 3.995-6.043 2.159-9.188l-6.241-10.736h8.951c3.519 0 6.789-2.585 6.789-6.406.001-3.883-3.269-6.477-6.789-6.477zM23.062 74.91l-3.53 6.17c-1.787 3.144-1.237 7.214 2.044 9.187 3.458 1.973 7.227.322 9.002-2.71l5.233-8.877c-1.236-2.284-6.219-5.503-12.751-3.769z"/>
                                                </svg>
                                                <span>App Store</span>
                                            }
                                            else
                                            {
                                                <!-- Google Play logo -->
                                                <svg width="13" height="13" viewBox="0 0 40 40">
                                                    <path fill="none" d="M0,0h40v40H0V0z"></path>
                                                    <g>
                                                        <path d="M19.7,19.2L4.3,35.3c0,0,0,0,0,0c0.5,1.7,2.1,3,4,3c0.8,0,1.5-0.2,2.1-0.6l0,0l17.4-9.9L19.7,19.2z" fill="#EA4335"></path>
                                                        <path d="M35.3,16.4L35.3,16.4l-7.5-4.3l-8.4,7.4l8.5,8.3l7.5-4.2c1.3-0.7,2.2-2.1,2.2-3.6C37.5,18.5,36.6,17.1,35.3,16.4z" fill="#FBBC04"></path>
                                                        <path d="M4.3,4.7C4.2,5,4.2,5.4,4.2,5.8v28.5c0,0.4,0,0.7,0.1,1.1l16-15.7L4.3,4.7z" fill="#4285F4"></path>
                                                        <path d="M19.8,20l8-7.9L10.5,2.3C9.9,1.9,9.1,1.7,8.3,1.7c-1.9,0-3.6,1.3-4,3c0,0,0,0,0,0L19.8,20z" fill="#34A853"></path>
                                                    </g>
                                                </svg>
                                                <span>Google Play</span>
                                            }
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

@code {

    [Parameter, EditorRequired]
    public Experience[] Experiences { get; set; } = default!;

}
