@using MeWeb.Models

<section id="experience" class="section alt-bg">
    <div class="container">
        <div class="section-title">Experience</div>
        <div class="timeline reveal">
            @foreach (var exp in Experiences)
            {
                <div class="timeline-item">
                    <div class="timeline-header">
                        <span class="timeline-title">@exp.Title</span>
                        <span style="color:var(--text-secondary)">—</span>
                        <span class="timeline-company">@exp.Company</span>
                    </div>
                    <div class="timeline-meta">
                        <span class="timeline-period">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M5.75 0a.75.75 0 0 1 .75.75V2h3V.75a.75.75 0 0 1 1.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0 1 12.25 16H3.75A1.75 1.75 0 0 1 2 14.25V3.75C2 2.784 2.784 2 3.75 2H5V.75A.75.75 0 0 1 5.75 0zm-2 3.5a.25.25 0 0 0-.25.25V6h9V3.75a.25.25 0 0 0-.25-.25H3.75zM13 7.5H3v6.75c0 .138.112.25.25.25h9.5a.25.25 0 0 0 .25-.25V7.5z"/></svg>
                            @exp.Period
                        </span>
                        <span class="timeline-location">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C5.24 0 3 2.24 3 5c0 3.75 5 11 5 11s5-7.25 5-11c0-2.76-2.24-5-5-5zm0 7.5C6.62 7.5 5.5 6.38 5.5 5S6.62 2.5 8 2.5 10.5 3.62 10.5 5 9.38 7.5 8 7.5z"/></svg>
                            @exp.Location
                        </span>
                    </div>
                    <ul class="timeline-bullets">
                        @foreach (var bullet in exp.Bullets)
                        {
                            <li>@bullet</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public Experience[] Experiences { get; set; } = default!;
}
