<section id="hero" class="section hero">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-name hero-animate">@Person.Name</h1>
                <p class="hero-title hero-animate">@Person.Title</p>

                <div class="hero-meta hero-animate">
                    <span class="hero-badge">
                        <!-- location pin -->
                        <LocationPinSvg Width="14" Height="14"/>
                        @Person.Location
                    </span>
                    <span class="hero-badge">
                        <!-- EU permit badge -->
                        <svg height="14" width="14" viewBox="0 -960 960 960" fill="currentColor">
                            <path
                                d="M130-189 81-546q-5-32 15.5-58t52.5-31l61 435 283-40h267q-8 21-24.5 35.5T695-187l-477 66q-33 5-58-15t-30-53Zm190-127q-33 0-56.5-23.5T240-396v-364q0-33 23.5-56.5T320-840h480q33 0 56.5 23.5T880-760v364q0 33-23.5 56.5T800-316H320Zm0-80h480v-364H320v364Zm0 0v-364 364ZM210-200Zm190-400h320v-80H400v80Zm0 120h200v-80H400v80Z"/>
                        </svg>
                        @Person.Permit
                    </span>
                </div>

                <div class="hero-actions hero-animate">
                    <a class="btn btn-primary" href="https://@Person.LinkedIn" target="_blank" rel="noopener">
                        LinkedIn
                    </a>
                    <a class="btn btn-outline" href="https://@Person.GitHub" target="_blank" rel="noopener">
                        GitHub
                    </a>
                </div>

                <div class="hero-links hero-animate">
                    <a class="hero-link" href="mailto:@Person.Email">
                        <!-- envelope -->
                        <svg height="14" width="14" viewBox="0 -960 960 960" fill="currentColor">
                            <path
                                d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm320-280L160-640v400h640v-400L480-440Zm0-80 320-200H160l320 200ZM160-640v-80 480-400Z"/>
                        </svg>
                        @Person.Email
                    </a>
                    <span class="hero-link">
                        <!-- phone handset -->
                        <svg height="14" width="14" viewBox="0 -960 960 960" fill="currentColor">
                            <path
                                d="M798-120q-125 0-247-54.5T329-329Q229-429 174.5-551T120-798q0-18 12-30t30-12h162q14 0 25 9.5t13 22.5l26 140q2 16-1 27t-11 19l-97 98q20 37 47.5 71.5T387-386q31 31 65 57.5t72 48.5l94-94q9-9 23.5-13.5T670-390l138 28q14 4 23 14.5t9 23.5v162q0 18-12 30t-30 12ZM241-600l66-66-17-94h-89q5 41 14 81t26 79Zm358 358q39 17 79.5 27t81.5 13v-88l-94-19-67 67ZM241-600Zm358 358Z"/>
                        </svg>
                        @Person.Phone
                    </span>
                </div>
            </div>

            <div class="hero-photo hero-animate">
                <img src="images/photo.jpeg" alt="@Person.Name" class="hero-avatar"/>
            </div>
        </div>
    </div>
</section>

@code {

    [Parameter, EditorRequired]
    public PersonInfo Person { get; set; } = default!;

}
